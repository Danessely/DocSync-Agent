# GitHub webhook / API
GITHUB_WEBHOOK_SECRET=replace-with-webhook-secret
GITHUB_TOKEN=replace-with-github-token

# Telegram clarification
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_TIMEOUT_SEC=10

# LLM provider
LLM_PROVIDER=mock
LLM_MODEL=mock-model
LLM_TIMEOUT_SEC=20
LLM_API_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=api-key-placeholder

# Retrieval / patch limits
DOC_PATH_ALLOWLIST=README.md,docs/
MAX_DIFF_LINES=1000
MAX_DOC_CANDIDATES=3
MAX_CHANGED_DOC_FILES=3
MAX_PATCH_LINES=200
MIN_CONFIDENCE=0.6

# Publishing / runtime
PUBLISH_MODE=comment_only
DRY_RUN=false
LOG_LEVEL=INFO
SESSION_STORE_PATH=.docsync/session_store.json
DOCS_VALIDATION_COMMAND=
DOCS_VALIDATION_TIMEOUT_SEC=30

LANGSMITH_TRACING=true
LANGSMITH_ENDPOINT=https://eu.api.smith.langchain.com
LANGSMITH_API_KEY=api-key-placeholder
LANGSMITH_PROJECT="docsync"
